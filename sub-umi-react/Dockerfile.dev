FROM node:24-alpine

WORKDIR /app

# 设置 npm 镜像
RUN npm config set registry https://registry.npmmirror.com

# 安装 pnpm
RUN npm install -g pnpm@10.33.0

# 设置 pnpm 镜像
RUN pnpm config set registry https://registry.npmmirror.com

# 复制依赖文件
COPY pnpm-lock.yaml pnpm-workspace.yaml ./

# 复制项目文件
COPY sub-umi-react/ ./

# 安装依赖
RUN pnpm install

# 暴露开发服务器端口
EXPOSE 8001

# 启动开发服务器
CMD ["pnpm", "run", "dev"]
